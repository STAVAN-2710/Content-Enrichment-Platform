# LLM Provider: zai | anthropic | azure_openai | openai
LLM_PROVIDER=zai
LLM_MODEL=gpt-4o

# z.ai (OpenAI-compatible)
ZAI_API_KEY=your_zai_api_key_here
ZAI_BASE_URL=https://api.z.ai/v1

# Anthropic (for benchmarking later)
ANTHROPIC_API_KEY=

# Azure OpenAI (for benchmarking later)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_DEPLOYMENT_NAME=

# Redis
REDIS_URL=redis://localhost:6379

# Pipeline
PIPELINE_CHUNK_SIZE=500
ENRICHMENT_SCHEMA_VERSION=1
PROMPT_VERSION=v1

# Paths (relative to project root)
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_ENRICHED_DIR=data/enriched
DATA_GOLDEN_DIR=data/golden
DATA_EMBEDDINGS_DIR=data/embeddings
CHECKPOINTER_DB=data/checkpointer.db
DEAD_LETTER_FILE=data/dead_letter.jsonl
