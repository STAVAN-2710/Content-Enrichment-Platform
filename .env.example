# LLM Provider: openai | zai
# Priority: OPENAI_API_KEY checked first, then ZAI_API_KEY
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini  # cheap + capable; use gpt-4o for highest quality

# OpenAI (primary)
OPENAI_API_KEY=your_openai_api_key_here

# z.ai (fallback — OpenAI-compatible, GLM models)
# Alternate base: https://open.bigmodel.cn/api/paas/v4 (Zhipu AI direct)
ZAI_API_KEY=your_zai_api_key_here
ZAI_BASE_URL=https://api.z.ai/api/v1

# Anthropic (for benchmarking later)
ANTHROPIC_API_KEY=


# Redis
REDIS_URL=redis://localhost:6379

# Pipeline
PIPELINE_CHUNK_SIZE=500
ENRICHMENT_SCHEMA_VERSION=1
PROMPT_VERSION=v1

# Paths (relative to project root)
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_ENRICHED_DIR=data/enriched
DATA_GOLDEN_DIR=data/golden
DATA_EMBEDDINGS_DIR=data/embeddings
CHECKPOINTER_DB=data/checkpointer.db
DEAD_LETTER_FILE=data/dead_letter.jsonl
